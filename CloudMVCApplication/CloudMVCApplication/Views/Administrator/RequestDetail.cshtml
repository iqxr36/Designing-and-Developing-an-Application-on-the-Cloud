@{
    Layout = "~/Views/Shared/_AdministratorLayout.cshtml";
    ViewData["Title"] = "Request Details";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">Request #REQ-4092</h2>
        <p class="admin-page-subtitle">HVAC System Failure - Major Leak Detected</p>
    </div>
    <div class="admin-page-actions">
        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="Maintenance">
            <span class="material-symbols-outlined">arrow_back</span> Back to Requests
        </a>
    </div>
</div>

@* TODO: Replace static request data with database lookup by requestId *@
<div class="admin-grid" style="grid-template-columns: 2fr 1fr; gap: 24px;">
    <div>
        <div class="admin-card admin-mb-3">
            <div class="admin-card__header">
                <h3 class="admin-card__title">Request Information</h3>
                <span class="admin-badge admin-badge--urgent">Urgent</span>
            </div>
            <div class="admin-card__body">
                <div class="admin-grid admin-grid--2cols admin-mb-3">
                    <div>
                        <p class="admin-text-muted admin-text-small" style="margin: 0;">Property</p>
                        <p style="font-weight: 600; margin: 4px 0 0;">The Grandeur Plaza</p>
                    </div>
                    <div>
                        <p class="admin-text-muted admin-text-small" style="margin: 0;">Unit</p>
                        <p style="font-weight: 600; margin: 4px 0 0;">Unit 4B</p>
                    </div>
                    <div>
                        <p class="admin-text-muted admin-text-small" style="margin: 0;">Submitted</p>
                        <p style="font-weight: 600; margin: 4px 0 0;">Oct 24, 2023 08:30 AM</p>
                    </div>
                    <div>
                        <p class="admin-text-muted admin-text-small" style="margin: 0;">Category</p>
                        <p style="font-weight: 600; margin: 4px 0 0;">HVAC</p>
                    </div>
                </div>
                <div class="admin-form-group">
                    <label class="admin-label">Description</label>
                    <p style="margin: 0; padding: 12px; background: var(--pm-surface-container); border-radius: 8px;">The HVAC system in Unit 4B has developed a major leak. Water is pooling near the intake vent. The tenant reports unusual noises and reduced cooling performance for the past 2 days before the leak appeared.</p>
                </div>
            </div>
        </div>
        <div class="admin-card">
            <div class="admin-card__header">
                <h3 class="admin-card__title">Activity Timeline</h3>
            </div>
            <div class="admin-activity">
                <div class="admin-activity__list">
                    <div class="admin-activity__item">
                        <span class="admin-activity__dot admin-activity__dot--primary"></span>
                        <p class="admin-activity__title">Request assigned to Sarah Jenkins</p>
                        <span class="admin-activity__time">Oct 24, 09:15 AM</span>
                    </div>
                    <div class="admin-activity__item">
                        <span class="admin-activity__dot admin-activity__dot--error"></span>
                        <p class="admin-activity__title">Request created</p>
                        <p class="admin-activity__desc">Marked as Urgent priority</p>
                        <span class="admin-activity__time">Oct 24, 08:30 AM</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div>
        <div class="admin-card admin-mb-3">
            <div class="admin-card__header">
                <h3 class="admin-card__title">Assigned Technician</h3>
            </div>
            <div class="admin-card__body">
                <div class="admin-flex admin-flex-center admin-gap-3 admin-mb-3">
                    <div style="width: 48px; height: 48px; border-radius: 999px; background: #e1e3e4; display: flex; align-items: center; justify-content: center; font-weight: 700;">SJ</div>
                    <div>
                        <p style="font-weight: 600; margin: 0;">Sarah Jenkins</p>
                        <p class="admin-text-muted admin-text-small" style="margin: 0;">HVAC Specialist</p>
                    </div>
                </div>
                <button class="admin-btn admin-btn--secondary" style="width: 100%;">Reassign</button>
            </div>
        </div>
        <div class="admin-card">
            <div class="admin-card__header">
                <h3 class="admin-card__title">Update Status</h3>
            </div>
            <div class="admin-card__body">
                <div class="admin-form-group">
                    <label class="admin-label">Status</label>
                    <select class="admin-select">
                        <option>Open</option>
                        <option>In Progress</option>
                        <option>On Hold</option>
                        <option>Completed</option>
                    </select>
                </div>
                <button class="admin-btn admin-btn--primary" style="width: 100%;">Update Status</button>
            </div>
        </div>
    </div>
</div>
