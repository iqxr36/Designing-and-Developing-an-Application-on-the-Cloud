@{
    Layout = "~/Views/Shared/_AdministratorLayout.cshtml";
    ViewData["Title"] = "Add Unit";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">Add New Unit</h2>
        <p class="admin-page-subtitle">Register a new unit to a property.</p>
    </div>
    <div class="admin-page-actions">
        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="Units">
            <span class="material-symbols-outlined">arrow_back</span> Back to Units
        </a>
    </div>
</div>

<div class="admin-form-card">
    <div class="admin-form-card__header">
        <h3 class="admin-form-card__title">Unit Information</h3>
    </div>
    <div class="admin-form-card__body">
        @* TODO: Connect form to Unit creation endpoint *@
        <div class="admin-grid admin-grid--2cols">
            <div class="admin-form-group">
                <label class="admin-label">Unit Number *</label>
                <input type="text" class="admin-input" placeholder="e.g., A-101" required />
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Property *</label>
                <select class="admin-select" required>
                    <option value="">Select property</option>
                    <option value="1">The Grand Plaza</option>
                    <option value="2">Riverfront Lofts</option>
                    <option value="3">Oakwood Estates</option>
                </select>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Unit Type *</label>
                <select class="admin-select" required>
                    <option value="">Select type</option>
                    <option value="studio">Studio</option>
                    <option value="1br">1 Bedroom</option>
                    <option value="2br">2 Bedroom</option>
                    <option value="penthouse">Penthouse</option>
                </select>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Square Footage</label>
                <input type="number" class="admin-input" placeholder="0" />
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Monthly Rent ($) *</label>
                <input type="number" class="admin-input" placeholder="0.00" required />
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Initial Status</label>
                <select class="admin-select">
                    <option value="vacant">Vacant</option>
                    <option value="occupied">Occupied</option>
                    <option value="maintenance">Maintenance</option>
                </select>
            </div>
        </div>
    </div>
    <div class="admin-form-card__footer">
        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="Units">Cancel</a>
        <button class="admin-btn admin-btn--primary">Add Unit</button>
    </div>
</div>
