@{
    Layout = "~/Views/Shared/_AdministratorLayout.cshtml";
    ViewData["Title"] = "Export Ready";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">Export Ready</h2>
        <p class="admin-page-subtitle">Your report has been generated and is ready for download.</p>
    </div>
    <div class="admin-page-actions">
        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="Reports">
            <span class="material-symbols-outlined">arrow_back</span> Back to Reports
        </a>
    </div>
</div>

<div class="admin-card" style="max-width: 600px; margin: 0 auto; text-align: center;">
    <div class="admin-card__body" style="padding: 48px;">
        <div style="width: 80px; height: 80px; border-radius: 999px; background: #c8ffc8; color: #006400; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
            <span class="material-symbols-outlined" style="font-size: 40px;">check_circle</span>
        </div>
        
        <h3 style="font-size: 24px; font-weight: 600; margin: 0 0 8px;">Export Complete!</h3>
        <p class="admin-text-muted" style="margin-bottom: 32px;">Your report has been successfully generated and is ready for download.</p>
        
        <div style="background: var(--pm-surface-container); border-radius: 12px; padding: 24px; margin-bottom: 32px; text-align: left;">
            <div class="admin-flex admin-flex-between admin-mb-2">
                <span class="admin-text-muted">Report Name:</span>
                <span style="font-weight: 500;">Monthly Maintenance Summary</span>
            </div>
            <div class="admin-flex admin-flex-between admin-mb-2">
                <span class="admin-text-muted">Format:</span>
                <span style="font-weight: 500;">PDF Document</span>
            </div>
            <div class="admin-flex admin-flex-between admin-mb-2">
                <span class="admin-text-muted">Date Range:</span>
                <span style="font-weight: 500;">Oct 1 - Oct 31, 2023</span>
            </div>
            <div class="admin-flex admin-flex-between">
                <span class="admin-text-muted">File Size:</span>
                <span style="font-weight: 500;">1.2 MB</span>
            </div>
        </div>
        
        @* TODO: Implement actual file download functionality *@
        <div class="admin-flex admin-flex-center admin-gap-3" style="justify-content: center;">
            <button class="admin-btn admin-btn--primary" style="padding: 12px 32px;">
                <span class="material-symbols-outlined">download</span>
                Download Report
            </button>
            <button class="admin-btn admin-btn--secondary">
                <span class="material-symbols-outlined">email</span>
                Email Report
            </button>
        </div>
        
        <p class="admin-text-muted admin-text-small" style="margin-top: 24px;">
            Download link expires in 24 hours. You can also find this report in your Downloads history.
        </p>
    </div>
</div>
