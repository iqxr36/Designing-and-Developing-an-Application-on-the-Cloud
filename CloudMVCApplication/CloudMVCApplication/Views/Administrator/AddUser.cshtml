@{
    Layout = "~/Views/Shared/_AdministratorLayout.cshtml";
    ViewData["Title"] = "Add New User";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">Add New User</h2>
        <p class="admin-page-subtitle">Create a new user account for the system.</p>
    </div>
    <div class="admin-page-actions">
        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="Users">
            <span class="material-symbols-outlined">arrow_back</span> Back to Users
        </a>
    </div>
</div>

<div class="admin-form-card">
    <div class="admin-form-card__header">
        <h3 class="admin-form-card__title">User Information</h3>
    </div>
    <div class="admin-form-card__body">
        @* TODO: Connect form to User creation endpoint *@
        <div class="admin-grid admin-grid--2cols">
            <div class="admin-form-group">
                <label class="admin-label">First Name *</label>
                <input type="text" class="admin-input" placeholder="Enter first name" required />
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Last Name *</label>
                <input type="text" class="admin-input" placeholder="Enter last name" required />
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Email Address *</label>
                <input type="email" class="admin-input" placeholder="user@example.com" required />
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Phone Number</label>
                <input type="tel" class="admin-input" placeholder="(555) 000-0000" />
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Role *</label>
                <select class="admin-select" required>
                    <option value="">Select a role</option>
                    <option value="admin">Admin</option>
                    <option value="property_manager">Property Manager</option>
                    <option value="technician">Technician</option>
                </select>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Status</label>
                <select class="admin-select">
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
        </div>
        <div class="admin-form-group">
            <label class="admin-label">Temporary Password *</label>
            <input type="password" class="admin-input" placeholder="Create a temporary password" required />
            <p class="admin-text-muted admin-text-small" style="margin-top: 4px;">User will be required to change password on first login.</p>
        </div>
    </div>
    <div class="admin-form-card__footer">
        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="Users">Cancel</a>
        <button class="admin-btn admin-btn--primary">Create User</button>
    </div>
</div>
