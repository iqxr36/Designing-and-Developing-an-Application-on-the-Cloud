@{
    Layout = "~/Views/Shared/_AdministratorLayout.cshtml";
    ViewData["Title"] = "Audit Log Details";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">Audit Log Entry</h2>
        <p class="admin-page-subtitle">Oct 24, 2023 14:32:01</p>
    </div>
    <div class="admin-page-actions">
        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="AuditLogs">
            <span class="material-symbols-outlined">arrow_back</span> Back to Audit Logs
        </a>
    </div>
</div>

@* TODO: Replace static audit log data with database lookup by logId *@
<div class="admin-grid" style="grid-template-columns: 1fr 1fr; gap: 24px;">
    <div class="admin-card">
        <div class="admin-card__header">
            <h3 class="admin-card__title">Event Information</h3>
        </div>
        <div class="admin-card__body">
            <div class="admin-form-group">
                <label class="admin-label">Action Type</label>
                <p><span class="admin-badge admin-badge--dark">Updated Property</span></p>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Entity</label>
                <p style="font-weight: 600;">Sunset Apartments (PROP-1042)</p>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Timestamp</label>
                <p>Oct 24, 2023 14:32:01 UTC</p>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">IP Address</label>
                <p style="font-family: monospace;">192.168.1.45</p>
            </div>
        </div>
    </div>
    <div class="admin-card">
        <div class="admin-card__header">
            <h3 class="admin-card__title">User Information</h3>
        </div>
        <div class="admin-card__body">
            <div class="admin-flex admin-flex-center admin-gap-3 admin-mb-3">
                <div style="width: 48px; height: 48px; border-radius: 999px; background: #d9e3f7; color: #1d2736; display: flex; align-items: center; justify-content: center; font-weight: 700;">JS</div>
                <div>
                    <p style="font-weight: 600; margin: 0;">Jane Smith</p>
                    <p class="admin-text-muted admin-text-small" style="margin: 0;">Admin</p>
                </div>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Email</label>
                <p>jane.smith@zammaintain.com</p>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">User Agent</label>
                <p class="admin-text-small" style="font-family: monospace; word-break: break-all;">Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/118.0</p>
            </div>
        </div>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card__header">
        <h3 class="admin-card__title">Changes Made</h3>
    </div>
    <div class="admin-table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Field</th>
                    <th>Previous Value</th>
                    <th>New Value</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Property Name</strong></td>
                    <td class="admin-text-muted">Sunset Apts</td>
                    <td>Sunset Apartments</td>
                </tr>
                <tr>
                    <td><strong>Total Units</strong></td>
                    <td class="admin-text-muted">45</td>
                    <td>48</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
