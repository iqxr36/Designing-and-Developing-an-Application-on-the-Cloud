@{
    Layout = "~/Views/Shared/_AdministratorLayout.cshtml";
    ViewData["Title"] = "Request Submitted";
}

<div style="max-width: 600px; margin: 80px auto; text-align: center;">
    <div style="width: 80px; height: 80px; border-radius: 999px; background: #d6f0e0; color: #0a5c2e; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
        <span class="material-symbols-outlined" style="font-size: 40px;">check_circle</span>
    </div>
    <h2 class="admin-page-title" style="margin-bottom: 8px;">Request Submitted Successfully</h2>
    <p class="admin-page-subtitle" style="margin-bottom: 32px;">Your maintenance request has been created and is now being processed.</p>
    
    <div class="admin-card" style="text-align: left; margin-bottom: 24px;">
        <div class="admin-card__body">
            <div class="admin-grid admin-grid--2cols">
                <div>
                    <p class="admin-text-muted admin-text-small" style="margin: 0;">Request ID</p>
                    <p style="font-weight: 600; margin: 4px 0 0; color: var(--pm-primary);">#REQ-4093</p>
                </div>
                <div>
                    <p class="admin-text-muted admin-text-small" style="margin: 0;">Status</p>
                    <p style="margin: 4px 0 0;"><span class="admin-badge admin-badge--pending">Open</span></p>
                </div>
                <div>
                    <p class="admin-text-muted admin-text-small" style="margin: 0;">Priority</p>
                    <p style="font-weight: 600; margin: 4px 0 0;">High</p>
                </div>
                <div>
                    <p class="admin-text-muted admin-text-small" style="margin: 0;">Assigned To</p>
                    <p style="font-weight: 600; margin: 4px 0 0;">Auto-assigning...</p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="admin-flex admin-gap-3" style="justify-content: center;">
        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="CreateRequest">Create Another</a>
        <a class="admin-btn admin-btn--primary" asp-controller="Administrator" asp-action="Maintenance">View All Requests</a>
    </div>
</div>
