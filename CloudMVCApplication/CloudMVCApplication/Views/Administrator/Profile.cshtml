@{
    Layout = "~/Views/Shared/_AdministratorLayout.cshtml";
    ViewData["Title"] = "My Profile";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">My Profile</h2>
        <p class="admin-page-subtitle">Manage your account settings and preferences.</p>
    </div>
</div>

<div class="admin-grid" style="grid-template-columns: 1fr 2fr; gap: 24px;">
    <div class="admin-card">
        <div class="admin-card__body" style="text-align: center;">
            <div style="width: 100px; height: 100px; border-radius: 999px; background: #333d4d; color: #9da8bb; display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: 700; margin: 0 auto 16px;">AU</div>
            <h3 style="font-size: 20px; font-weight: 600; margin: 0 0 4px;">Admin User</h3>
            <p class="admin-text-muted">admin@zammaintain.com</p>
            <span class="admin-badge admin-badge--dark" style="margin-top: 12px;">Admin</span>
            <div style="margin-top: 24px;">
                <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="ChangeAvatar" style="width: 100%;">Change Avatar</a>
            </div>
        </div>
    </div>
    <div class="admin-form-card">
        <div class="admin-form-card__header">
            <h3 class="admin-form-card__title">Profile Information</h3>
        </div>
        <div class="admin-form-card__body">
            @* TODO: Connect form to User update endpoint *@
            <div class="admin-grid admin-grid--2cols">
                <div class="admin-form-group">
                    <label class="admin-label">First Name</label>
                    <input type="text" class="admin-input" value="Admin" />
                </div>
                <div class="admin-form-group">
                    <label class="admin-label">Last Name</label>
                    <input type="text" class="admin-input" value="User" />
                </div>
                <div class="admin-form-group">
                    <label class="admin-label">Email</label>
                    <input type="email" class="admin-input" value="admin@zammaintain.com" disabled style="background: var(--pm-surface-container); cursor: not-allowed;" />
                </div>
                <div class="admin-form-group">
                    <label class="admin-label">Phone</label>
                    <input type="tel" class="admin-input" value="(555) 000-0000" />
                </div>
            </div>
        </div>
        <div class="admin-form-card__footer">
            <button class="admin-btn admin-btn--primary">Save Changes</button>
        </div>
    </div>
</div>

<div class="admin-form-card" style="margin-top: 24px;">
    <div class="admin-form-card__header">
        <h3 class="admin-form-card__title">Change Password</h3>
    </div>
    <div class="admin-form-card__body">
        <div class="admin-grid admin-grid--3cols">
            <div class="admin-form-group">
                <label class="admin-label">Current Password</label>
                <input type="password" class="admin-input" placeholder="Enter current password" />
            </div>
            <div class="admin-form-group">
                <label class="admin-label">New Password</label>
                <input type="password" class="admin-input" placeholder="Enter new password" />
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Confirm Password</label>
                <input type="password" class="admin-input" placeholder="Confirm new password" />
            </div>
        </div>
    </div>
    <div class="admin-form-card__footer">
        <button class="admin-btn admin-btn--primary">Update Password</button>
    </div>
</div>
