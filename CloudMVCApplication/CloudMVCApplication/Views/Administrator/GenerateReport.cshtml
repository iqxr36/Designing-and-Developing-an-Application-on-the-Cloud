@{
    Layout = "~/Views/Shared/_AdministratorLayout.cshtml";
    ViewData["Title"] = "Generate Report";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">Generate Report</h2>
        <p class="admin-page-subtitle">Create a custom report based on your criteria.</p>
    </div>
    <div class="admin-page-actions">
        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="Reports">
            <span class="material-symbols-outlined">arrow_back</span> Back to Reports
        </a>
    </div>
</div>

<div class="admin-form-card">
    <div class="admin-form-card__header">
        <h3 class="admin-form-card__title">Report Configuration</h3>
    </div>
    <div class="admin-form-card__body">
        @* TODO: Connect form to Report generation endpoint *@
        <div class="admin-grid admin-grid--2cols">
            <div class="admin-form-group">
                <label class="admin-label">Report Type *</label>
                <select class="admin-select" required>
                    <option value="">Select report type</option>
                    <option value="maintenance">Maintenance Summary</option>
                    <option value="technician">Technician Workload</option>
                    <option value="vacancy">Vacancy & Unit Status</option>
                    <option value="financial">Financial Overview</option>
                </select>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Date Range *</label>
                <select class="admin-select" required>
                    <option value="">Select period</option>
                    <option value="7d">Last 7 Days</option>
                    <option value="30d">Last 30 Days</option>
                    <option value="quarter">This Quarter</option>
                    <option value="year">This Year</option>
                    <option value="custom">Custom Range</option>
                </select>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Properties</label>
                <select class="admin-select">
                    <option value="">All Properties</option>
                    <option value="1">The Grand Plaza</option>
                    <option value="2">Riverfront Lofts</option>
                    <option value="3">Oakwood Estates</option>
                </select>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Format</label>
                <select class="admin-select">
                    <option value="pdf">PDF</option>
                    <option value="excel">Excel</option>
                    <option value="csv">CSV</option>
                </select>
            </div>
        </div>
        <div class="admin-form-group">
            <label class="admin-label">Report Name</label>
            <input type="text" class="admin-input" placeholder="Custom report name (optional)" />
        </div>
    </div>
    <div class="admin-form-card__footer">
        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="Reports">Cancel</a>
        <a class="admin-btn admin-btn--primary" asp-controller="Administrator" asp-action="ExportReady">Generate Report</a>
    </div>
</div>
