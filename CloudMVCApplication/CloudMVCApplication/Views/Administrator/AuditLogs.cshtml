                            <span class="material-symbols-outlined">chevron_right</span>
                        </a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="admin-pagination">
        <span class="admin-text-muted admin-text-small" style="margin-right: auto;">
            Showing <strong>1</strong> to <strong>5</strong> of <strong>1,240</strong> entries
        </span>
        <button class="admin-pagination__btn" style="opacity: 0.5;">Previous</button>
        <button class="admin-pagination__btn admin-pagination__btn--active">1</button>
        <button class="admin-pagination__btn">2</button>
        <button class="admin-pagination__btn">3</button>
        <span class="admin-text-muted">...</span>
        <button class="admin-pagination__btn">Next</button>
    </div>
</div>
