@{
    Layout = "~/Views/Shared/_AdministratorLayout.cshtml";
    ViewData["Title"] = "System Audit Logs";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">System Audit Logs</h2>
        <p class="admin-page-subtitle">Track and monitor all system activity and security events.</p>
    </div>
    <div class="admin-page-actions">
        <button class="admin-btn admin-btn--secondary">
            <span class="material-symbols-outlined">download</span> Export CSV
        </button>
    </div>
</div>

<div class="admin-filters">
    <div class="admin-filters__group">
        <label>Date Range</label>
        <div style="position: relative;">
            <span class="material-symbols-outlined" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--pm-on-surface-variant);">calendar_today</span>
            <input type="text" class="admin-input" placeholder="Last 7 Days" style="padding-left: 40px;" />
        </div>
    </div>
    <div class="admin-filters__group">
        <label>User Role</label>
        <select class="admin-select">
            <option>All Roles</option>
            <option>Admin</option>
            <option>Property Manager</option>
            <option>Maintenance Staff</option>
        </select>
    </div>
    <div class="admin-filters__group">
        <label>Action Type</label>
        <select class="admin-select">
            <option>All Actions</option>
            <option>Login/Logout</option>
            <option>Data Creation</option>
            <option>Data Modification</option>
            <option>Data Deletion</option>
        </select>
    </div>
    <button class="admin-btn admin-btn--primary" style="align-self: flex-end;">Apply Filters</button>
    <button class="admin-btn admin-btn--secondary" style="align-self: flex-end; padding: 0 12px;">
        <span class="material-symbols-outlined">refresh</span>
    </button>
</div>

<div class="admin-card">
    <div class="admin-table-wrap">
        @* TODO: Replace static audit log list with AuditLogs table data *@
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>IP Address</th>
                    <th class="admin-text-end">Details</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="admin-text-muted">Oct 24, 2023 14:32:01</td>
                    <td>
                        <div class="admin-flex admin-flex-center admin-gap-3">
                            <div style="width: 32px; height: 32px; border-radius: 999px; background: #d9e3f7; color: #1d2736; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700;">JS</div>
                            <div>
                                <p style="font-weight: 600; margin: 0;">Jane Smith</p>
                                <p class="admin-text-muted admin-text-small" style="margin: 0;">Admin</p>
                            </div>
                        </div>
                    </td>
                    <td><span class="admin-badge admin-badge--dark">Updated Property</span></td>
                    <td>
                        <a asp-controller="Administrator" asp-action="PropertyDetail" style="color: var(--pm-primary); font-weight: 600;">Sunset Apartments</a>
                        <p class="admin-text-muted admin-text-small" style="margin: 0;">ID: PROP-1042</p>
                    </td>
                    <td class="admin-text-muted" style="font-family: monospace;">192.168.1.45</td>
                    <td class="admin-text-end">
                        <a class="admin-btn admin-btn--link" asp-controller="Administrator" asp-action="AuditLogDetail">
                            <span class="material-symbols-outlined">chevron_right</span>
                        </a>
                    </td>
                </tr>
                <tr>
                    <td class="admin-text-muted">Oct 24, 2023 13:15:44</td>
                    <td>
                        <div class="admin-flex admin-flex-center admin-gap-3">
                            <div style="width: 32px; height: 32px; border-radius: 999px; background: #e1e1c9; color: #5e604d; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700;">MR</div>
                            <div>
                                <p style="font-weight: 600; margin: 0;">Mark Rogers</p>
                                <p class="admin-text-muted admin-text-small" style="margin: 0;">Property Manager</p>
                            </div>
                        </div>
                    </td>
                    <td><span class="admin-badge" style="background: #800000; color: #fff;">Created Request</span></td>
                    <td>
                        <a asp-controller="Administrator" asp-action="RequestDetail" style="color: var(--pm-primary); font-weight: 600;">Plumbing Issue Unit 4B</a>
                        <p class="admin-text-muted admin-text-small" style="margin: 0;">ID: REQ-8821</p>
                    </td>
                    <td class="admin-text-muted" style="font-family: monospace;">10.0.0.112</td>
                    <td class="admin-text-end">
                        <a class="admin-btn admin-btn--link" asp-controller="Administrator" asp-action="AuditLogDetail">
                            <span class="material-symbols-outlined">chevron_right</span>
                        </a>
                    </td>
                </tr>
                <tr>
                    <td class="admin-text-muted">Oct 24, 2023 09:02:11</td>
                    <td>
                        <div class="admin-flex admin-flex-center admin-gap-3">
                            <div style="width: 32px; height: 32px; border-radius: 999px; background: #d9e3f7; color: #1d2736; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700;">AL</div>
                            <div>
                                <p style="font-weight: 600; margin: 0;">Alex Lee</p>
                                <p class="admin-text-muted admin-text-small" style="margin: 0;">Maintenance Staff</p>
                            </div>
                        </div>
                    </td>
                    <td><span class="admin-badge admin-badge--pending">Status Change</span></td>
                    <td>
                        <a asp-controller="Administrator" asp-action="RequestDetail" style="color: var(--pm-primary); font-weight: 600;">HVAC Repair Main Lobby</a>
                        <p class="admin-text-muted admin-text-small" style="margin: 0;">ID: REQ-8819 (In Progress)</p>
                    </td>
                    <td class="admin-text-muted" style="font-family: monospace;">172.16.254.1</td>
                    <td class="admin-text-end">
                        <a class="admin-btn admin-btn--link" asp-controller="Administrator" asp-action="AuditLogDetail">
                            <span class="material-symbols-outlined">chevron_right</span>
                        </a>
                    </td>
                </tr>
                <tr>
                    <td class="admin-text-muted">Oct 23, 2023 16:20:12</td>
                    <td>
                        <div class="admin-flex admin-flex-center admin-gap-3">
                            <div style="width: 32px; height: 32px; border-radius: 999px; background: #ffdad6; color: #93000a; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700;">SYS</div>
                            <div>
                                <p style="font-weight: 600; margin: 0;">System Auto</p>
                                <p class="admin-text-muted admin-text-small" style="margin: 0;">Automated Process</p>
                            </div>
                        </div>
                    </td>
                    <td><span class="admin-badge admin-badge--urgent">Failed Login Attempt</span></td>
                    <td>
                        <span style="font-weight: 600;">Unknown User</span>
