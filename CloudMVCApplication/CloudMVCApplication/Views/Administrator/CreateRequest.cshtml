@{
    Layout = "~/Views/Shared/_AdministratorLayout.cshtml";
    ViewData["Title"] = "Create Request";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">Create Maintenance Request</h2>
        <p class="admin-page-subtitle">Submit a new maintenance request for processing.</p>
    </div>
    <div class="admin-page-actions">
        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="Maintenance">
            <span class="material-symbols-outlined">arrow_back</span> Back to Requests
        </a>
    </div>
</div>

<div class="admin-form-card">
    <div class="admin-form-card__header">
        <h3 class="admin-form-card__title">Request Details</h3>
    </div>
    <div class="admin-form-card__body">
        @* TODO: Connect form to MaintenanceRequest creation endpoint *@
        <div class="admin-grid admin-grid--2cols">
            <div class="admin-form-group">
                <label class="admin-label">Property *</label>
                <select class="admin-select" required>
                    <option value="">Select property</option>
                    <option value="1">The Grandeur Plaza</option>
                    <option value="2">Oakridge Heights</option>
                    <option value="3">Riverside Complex</option>
                </select>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Unit *</label>
                <select class="admin-select" required>
                    <option value="">Select unit</option>
                    <option value="1">Unit 4B</option>
                    <option value="2">Unit 12A</option>
                    <option value="3">Lobby</option>
                </select>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Category *</label>
                <select class="admin-select" required>
                    <option value="">Select category</option>
                    <option value="hvac">HVAC</option>
                    <option value="plumbing">Plumbing</option>
                    <option value="electrical">Electrical</option>
                    <option value="appliance">Appliance</option>
                    <option value="structural">Structural</option>
                    <option value="other">Other</option>
                </select>
            </div>
            <div class="admin-form-group">
                <label class="admin-label">Priority *</label>
                <select class="admin-select" required>
                    <option value="">Select priority</option>
                    <option value="urgent">Urgent</option>
                    <option value="high">High</option>
                    <option value="medium">Medium</option>
                    <option value="low">Low</option>
                </select>
            </div>
        </div>
        <div class="admin-form-group">
            <label class="admin-label">Issue Title *</label>
            <input type="text" class="admin-input" placeholder="Brief description of the issue" required />
        </div>
        <div class="admin-form-group">
            <label class="admin-label">Detailed Description *</label>
            <textarea class="admin-textarea" rows="5" placeholder="Provide as much detail as possible about the issue..." required style="resize: vertical;"></textarea>
        </div>
        <div class="admin-form-group">
            <label class="admin-label">Assign To</label>
            <select class="admin-select">
                <option value="">Auto-assign based on availability</option>
                <option value="1">Sarah Jenkins (HVAC Specialist)</option>
                <option value="2">Marcus Cole (General Maintenance)</option>
                <option value="3">David Chen (Plumbing)</option>
            </select>
        </div>
    </div>
    <div class="admin-form-card__footer">
        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="Maintenance">Cancel</a>
        <a class="admin-btn admin-btn--primary" asp-controller="Administrator" asp-action="RequestSubmitted">Submit Request</a>
    </div>
</div>
