@{
    Layout = "~/Views/Shared/_AdministratorLayout.cshtml";
    ViewData["Title"] = "System Settings";
}

<div class="admin-page-header">
    <div>
        <h2 class="admin-page-title">System Settings</h2>
        <p class="admin-page-subtitle">Manage your enterprise account configuration, notifications, and branding.</p>
    </div>
</div>

<div class="admin-grid" style="grid-template-columns: 1fr 2fr; gap: 24px;">
    <div>
        <div class="admin-card">
            <div class="admin-card__body">
                <h3 style="font-size: 18px; font-weight: 600; margin: 0 0 16px; padding-bottom: 8px; border-bottom: 1px solid var(--pm-outline-variant);">Settings Menu</h3>
                <nav style="display: flex; flex-direction: column; gap: 4px;">
                    <a href="#profile" style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border-radius: 8px; background: var(--pm-surface-container); color: var(--pm-primary); font-weight: 600; text-decoration: none; border-left: 2px solid var(--pm-primary);">
                        Profile
                        <span class="material-symbols-outlined" style="font-size: 18px;">chevron_right</span>
                    </a>
                    <a href="#organization" style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border-radius: 8px; color: var(--pm-on-surface-variant); text-decoration: none;">
                        Organization Details
                        <span class="material-symbols-outlined" style="font-size: 18px;">chevron_right</span>
                    </a>
                    <a href="#notifications" style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border-radius: 8px; color: var(--pm-on-surface-variant); text-decoration: none;">
                        Notification Preferences
                        <span class="material-symbols-outlined" style="font-size: 18px;">chevron_right</span>
                    </a>
                    <a href="#branding" style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border-radius: 8px; color: var(--pm-on-surface-variant); text-decoration: none;">
                        Branding &amp; Appearance
                        <span class="material-symbols-outlined" style="font-size: 18px;">chevron_right</span>
                    </a>
                </nav>
            </div>
        </div>
    </div>
    <div style="display: flex; flex-direction: column; gap: 24px;">
        <section id="profile" class="admin-form-card">
            <div class="admin-form-card__header">
                <div class="admin-flex admin-flex-center admin-gap-3">
                    <div style="width: 48px; height: 48px; border-radius: 999px; background: #e1e1c9; display: flex; align-items: center; justify-content: center;">
                        <span class="material-symbols-outlined" style="color: #474836;">person</span>
                    </div>
                    <div>
                        <h3 class="admin-form-card__title">Profile Information</h3>
                        <p class="admin-text-muted admin-text-small" style="margin: 0;">Update your personal account details.</p>
                    </div>
                </div>
            </div>
            <div class="admin-form-card__body">
                <div class="admin-flex admin-flex-center admin-gap-3 admin-mb-4">
                    <div style="width: 80px; height: 80px; border-radius: 999px; background: #333d4d; color: #9da8bb; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 700;">AU</div>
                    <div class="admin-flex admin-gap-2">
                        <a class="admin-btn admin-btn--secondary" asp-controller="Administrator" asp-action="ChangeAvatar">Change Avatar</a>
                        <button class="admin-btn admin-btn--link" style="color: #ba1a1a;">Remove</button>
                    </div>
                </div>
                <div class="admin-grid admin-grid--2cols">
                    <div class="admin-form-group">
                        <label class="admin-label">First Name</label>
                        <input type="text" class="admin-input" value="Admin" />
                    </div>
                    <div class="admin-form-group">
                        <label class="admin-label">Last Name</label>
                        <input type="text" class="admin-input" value="User" />
                    </div>
                </div>
                <div class="admin-form-group">
                    <label class="admin-label">Email Address</label>
                    <input type="email" class="admin-input" value="admin@zammaintain.com" disabled style="background: var(--pm-surface-container); cursor: not-allowed;" />
                </div>
            </div>
            <div class="admin-form-card__footer">
                <button class="admin-btn admin-btn--primary">Save Profile</button>
            </div>
        </section>

        <section id="organization" class="admin-form-card">
            <div class="admin-form-card__header">
                <div class="admin-flex admin-flex-center admin-gap-3">
                    <div style="width: 48px; height: 48px; border-radius: 999px; background: #e1e1c9; display: flex; align-items: center; justify-content: center;">
                        <span class="material-symbols-outlined" style="color: #474836;">domain</span>
                    </div>
                    <div>
                        <h3 class="admin-form-card__title">Organization</h3>
                        <p class="admin-text-muted admin-text-small" style="margin: 0;">Manage company-level identity and operating details.</p>
                    </div>
                </div>
            </div>
            <div class="admin-form-card__body">
                <div class="admin-grid admin-grid--2cols">
                    <div class="admin-form-group">
                        <label class="admin-label">Organization Name</label>
                        <input type="text" class="admin-input" value="ZamMaintain Operations" />
                    </div>
                    <div class="admin-form-group">
                        <label class="admin-label">Support Email</label>
                        <input type="email" class="admin-input" value="support@zammaintain.com" />
                    </div>
                </div>
            </div>
            <div class="admin-form-card__footer">
                <button class="admin-btn admin-btn--primary">Save Organization</button>
            </div>
        </section>

        <section id="notifications" class="admin-form-card">
            <div class="admin-form-card__header">
                <div class="admin-flex admin-flex-center admin-gap-3">
                    <div style="width: 48px; height: 48px; border-radius: 999px; background: #e1e1c9; display: flex; align-items: center; justify-content: center;">
                        <span class="material-symbols-outlined" style="color: #474836;">notifications</span>
                    </div>
                    <div>
                        <h3 class="admin-form-card__title">Notifications</h3>
                        <p class="admin-text-muted admin-text-small" style="margin: 0;">Choose which operational alerts should reach administrators.</p>
                    </div>
                </div>
            </div>
            <div class="admin-form-card__body">
                <label style="display: flex; align-items: center; justify-content: space-between; padding: 16px; border: 1px solid var(--pm-outline-variant); border-radius: 8px; margin-bottom: 12px; cursor: pointer;">
                    <span>
                        <strong style="display: block;">Urgent maintenance alerts</strong>
                        <span class="admin-text-muted admin-text-small">Notify admins when urgent requests are created.</span>
                    </span>
                    <input type="checkbox" checked />
                </label>
                <label style="display: flex; align-items: center; justify-content: space-between; padding: 16px; border: 1px solid var(--pm-outline-variant); border-radius: 8px; cursor: pointer;">
                    <span>
                        <strong style="display: block;">Weekly report summaries</strong>
                        <span class="admin-text-muted admin-text-small">Send portfolio summaries every Monday morning.</span>
                    </span>
                    <input type="checkbox" checked />
                </label>
            </div>
            <div class="admin-form-card__footer">
                <button class="admin-btn admin-btn--primary">Save Notifications</button>
            </div>
        </section>

        <section id="branding" class="admin-form-card">
            <div class="admin-form-card__header">
                <div class="admin-flex admin-flex-center admin-gap-3">
                    <div style="width: 48px; height: 48px; border-radius: 999px; background: #e1e1c9; display: flex; align-items: center; justify-content: center;">
                        <span class="material-symbols-outlined" style="color: #474836;">palette</span>
                    </div>
                    <div>
                        <h3 class="admin-form-card__title">Branding &amp; Appearance</h3>
                        <p class="admin-text-muted admin-text-small" style="margin: 0;">Keep the prototype aligned with the ZamMaintain admin identity.</p>
                    </div>
                </div>
            </div>
            <div class="admin-form-card__body">
                <div class="admin-grid admin-grid--2cols">
                    <div class="admin-form-group">
                        <label class="admin-label">Primary Color</label>
                        <input type="text" class="admin-input" value="#570000" />
                    </div>
                    <div class="admin-form-group">
                        <label class="admin-label">Sidebar Theme</label>
                        <select class="admin-select">
                            <option>Enterprise Dark</option>
                            <option>Classic Light</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="admin-form-card__footer">
                <button class="admin-btn admin-btn--primary">Save Branding</button>
            </div>
        </section>
    </div>
</div>
