@{
    var current = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<aside class="manager-sidebar pm-sidebar" aria-label="Manager navigation">
    <div class="pm-sidebar__brand">
        <div class="pm-sidebar__logo">PM</div>
        <div>
            <h1 class="pm-sidebar__title">PropMaintain</h1>
            <p class="pm-sidebar__subtitle">Cloud Maintenance Admin</p>
        </div>
    </div>
    <nav class="pm-sidebar__nav">
        <a class="pm-sidebar__link @(current == "Dashboard" ? "pm-sidebar__link--active" : null)" asp-controller="Manager" asp-action="Dashboard">
            <span class="material-symbols-outlined" aria-hidden="true">dashboard</span>
            Dashboard
        </a>
        <a class="pm-sidebar__link @(current == "MaintenanceRequests" ? "pm-sidebar__link--active" : null)" asp-controller="Manager" asp-action="MaintenanceRequests">
            <span class="material-symbols-outlined" aria-hidden="true">build</span>
            Maintenance Requests
        </a>
        <a class="pm-sidebar__link @(current == "RequestDetails" ? "pm-sidebar__link--active" : null)" asp-controller="Manager" asp-action="RequestDetails">
            <span class="material-symbols-outlined" aria-hidden="true">description</span>
            Request Details
        </a>
        <a class="pm-sidebar__link @(current == "AssignTechnician" ? "pm-sidebar__link--active" : null)" asp-controller="Manager" asp-action="AssignTechnician">
            <span class="material-symbols-outlined" aria-hidden="true">person_add</span>
            Assign Technician
        </a>
        <a class="pm-sidebar__link @(current == "TechnicianWorkload" ? "pm-sidebar__link--active" : null)" asp-controller="Manager" asp-action="TechnicianWorkload">
            <span class="material-symbols-outlined" aria-hidden="true">group</span>
            Technician Workload
        </a>
        <a class="pm-sidebar__link @(current == "CompletedRepairs" ? "pm-sidebar__link--active" : null)" asp-controller="Manager" asp-action="CompletedRepairs">
            <span class="material-symbols-outlined" aria-hidden="true">task_alt</span>
            Completed Repairs
        </a>
        <a class="pm-sidebar__link @(current == "Reports" ? "pm-sidebar__link--active" : null)" asp-controller="Manager" asp-action="Reports">
            <span class="material-symbols-outlined" aria-hidden="true">assessment</span>
            Reports / Summary
        </a>
        <a class="pm-sidebar__link @(current == "Notifications" ? "pm-sidebar__link--active" : null)" asp-controller="Manager" asp-action="Notifications">
            <span class="material-symbols-outlined" aria-hidden="true">notifications</span>
            Notifications
        </a>
        <a class="pm-sidebar__link @(current == "Profile" ? "pm-sidebar__link--active" : null)" asp-controller="Manager" asp-action="Profile">
            <span class="material-symbols-outlined" aria-hidden="true">account_circle</span>
            Profile / Account Settings
        </a>
    </nav>
</aside>
