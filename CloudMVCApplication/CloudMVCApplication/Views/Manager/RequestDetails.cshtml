@{
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
    ViewData["Title"] = "Request Details";
}
@* TODO: Load request + tenant + property + evidence URLs from database by route id *@
<div class="pm-flex-between pm-page-header">
    <div>
        <a class="pm-link-back" asp-controller="Manager" asp-action="MaintenanceRequests"><span class="material-symbols-outlined" style="font-size:18px">arrow_back</span> Back to Requests</a>
        <div class="d-flex flex-wrap align-items-center gap-2">
            <h1 class="pm-page-title mb-0">Request Details</h1>
            <span class="pm-badge pm-badge--inprogress">In Progress</span>
        </div>
        <p class="pm-page-lead pm-mt-1">Sample record REQ-2026-0894 &mdash; plumbing leak (static).</p>
    </div>
    <div class="pm-actions">
        <button type="button" class="pm-btn pm-btn--secondary" disabled title="UI only">Update Priority</button>
        <button type="button" class="pm-btn pm-btn--outline" disabled title="UI only">Mark as Reviewed</button>
        <a class="pm-btn pm-btn--primary" asp-controller="Manager" asp-action="AssignTechnician"><span class="material-symbols-outlined" style="font-size:18px">person_add</span> Assign Technician</a>
    </div>
</div>

<div class="pm-grid pm-grid--12">
    <div class="d-flex flex-column gap-3">
        <div class="pm-card">
            <div class="pm-card__body">
                <div class="pm-flex-between mb-3">
                    <div>
                        <h2 class="h5 mb-1">Water leak in kitchen</h2>
                        <p class="pm-muted mb-0">REQ-2026-0894</p>
                    </div>
                    <span class="pm-badge pm-badge--high">High</span>
                </div>
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="pm-label">Location</div>
                        <p class="mb-0"><strong>The Grand Ridge Apartments</strong></p>
                        <p class="pm-muted mb-0">Unit 402B, Building 4</p>
                    </div>
                    <div class="col-md-6">
                        <div class="pm-label">Tenant</div>
                        <p class="mb-0"><strong>Jane Doe</strong></p>
                        <p class="pm-muted mb-0">jane.doe@example.com</p>
                    </div>
                    <div class="col-md-6">
                        <div class="pm-label">Category</div>
                        <p class="mb-0">Plumbing</p>
                    </div>
                    <div class="col-md-6">
                        <div class="pm-label">Date submitted</div>
                        <p class="mb-0">May 12, 2026 &middot; 08:30</p>
                    </div>
                </div>
                <hr class="my-4" />
                <div class="pm-label">Description</div>
                <p class="mb-0">Water pooling under the kitchen sink from the main pipe joint. Tenant placed a bucket; expedited review recommended.</p>
            </div>
        </div>

        <div class="pm-card">
            <div class="pm-card__header">
                <h2 class="pm-card__title">Issue evidence (placeholder)</h2>
            </div>
            <div class="pm-card__body">
                <div class="row g-3">
                    <div class="col-6 col-md-4">
                        <img class="img-fluid rounded border" src="https://placehold.co/400x400/cfe2ff/0d6efd?text=Photo+1" alt="Evidence placeholder 1" />
                    </div>
                    <div class="col-6 col-md-4">
                        <img class="img-fluid rounded border" src="https://placehold.co/400x400/cfe2ff/0d6efd?text=Photo+2" alt="Evidence placeholder 2" />
                    </div>
                    <div class="col-12 col-md-4 d-flex align-items-center justify-content-center border border-2 border-dashed rounded text-center pm-muted p-3">
                        Additional uploads will appear here after database integration.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex flex-column gap-3">
        <div class="pm-card">
            <div class="pm-card__header">
                <h2 class="pm-card__title">Assignment</h2>
            </div>
            <div class="pm-card__body">
                <div class="d-flex gap-3 align-items-center mb-3">
                    <img class="rounded-circle border" src="https://placehold.co/96x96/374151/FFFFFF?text=MJ" width="48" height="48" alt="Technician placeholder" />
                    <div>
                        <strong>Marcus Johnson</strong>
                        <div class="pm-muted" style="font-size:.875rem">Senior plumber</div>
                    </div>
                </div>
                <p class="mb-1"><span class="material-symbols-outlined" style="font-size:18px;vertical-align:middle">phone</span> (555) 123-4567</p>
                <p class="mb-3"><span class="material-symbols-outlined" style="font-size:18px;vertical-align:middle">event</span> Assigned May 12, 10:15</p>
                <div class="pm-label">Current progress</div>
                <div class="pm-flex-between pm-mt-1"><span class="pm-muted">Workflow</span><span>60%</span></div>
                <div class="pm-progress pm-mt-1"><div class="pm-progress__bar" style="width:60%"></div></div>
                <p class="pm-muted pm-mt-1 mb-0" style="font-size:.85rem">En route to property (sample text).</p>
            </div>
        </div>

        <div class="pm-card">
            <div class="pm-card__header">
                <h2 class="pm-card__title">Repair update timeline</h2>
            </div>
            <div class="pm-card__body">
                <div class="pm-timeline">
                    <div class="pm-timeline__item">
                        <strong>Request submitted</strong> <span class="pm-badge pm-badge--pending">Pending</span>
                        <div class="pm-muted" style="font-size:.875rem">May 12, 08:30</div>
                    </div>
                    <div class="pm-timeline__item">
                        <strong>Assigned to Marcus J.</strong> <span class="pm-badge pm-badge--assigned">Assigned</span>
                        <div class="pm-muted" style="font-size:.875rem">May 12, 10:15</div>
                    </div>
                    <div class="pm-timeline__item pm-timeline__item--current">
                        <strong>In progress</strong> <span class="pm-badge pm-badge--inprogress">In Progress</span>
                        <div class="pm-muted" style="font-size:.875rem">May 12, 11:00</div>
                    </div>
                    <div class="pm-timeline__item pm-timeline__item--muted">
                        <strong>Completed</strong>
                        <div class="pm-muted" style="font-size:.875rem">Awaiting completion update</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
