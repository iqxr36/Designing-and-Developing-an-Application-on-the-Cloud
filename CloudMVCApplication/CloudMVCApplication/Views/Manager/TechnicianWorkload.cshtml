@{
    Layout = "~/Views/Shared/_ManagerLayout.cshtml";
    ViewData["Title"] = "Technician Workload";
}
<div class="pm-flex-between pm-page-header">
    <div>
        <h1 class="pm-page-title">Technician Workload</h1>
        <p class="pm-page-lead">Monitor assignments and balance team capacity (sample data).</p>
    </div>
    <div class="pm-actions">
        <button type="button" class="pm-btn pm-btn--secondary" disabled title="UI only">Export</button>
        <a class="pm-btn pm-btn--primary" asp-controller="Manager" asp-action="AssignTechnician">Assign ticket</a>
    </div>
</div>

<div class="pm-grid pm-grid--stats pm-mb-2">
    <div class="pm-stat"><div class="pm-stat__label">Total technicians</div><div class="pm-stat__value">24</div></div>
    <div class="pm-stat"><div class="pm-stat__label">Available</div><div class="pm-stat__value">8</div></div>
    <div class="pm-stat"><div class="pm-stat__label">Busy</div><div class="pm-stat__value">14</div></div>
    <div class="pm-stat"><div class="pm-stat__label">On leave</div><div class="pm-stat__value">2</div></div>
</div>

<div class="row g-4 align-items-start">
    <div class="col-lg-8">
        <div class="pm-card">
            <div class="pm-card__header">
                <h2 class="pm-card__title">Active roster &amp; workload</h2>
            </div>
            <div class="pm-table-wrap">
                @* TODO: Replace workload table with TechnicianProfiles + live job counts *@
                <table class="pm-table">
                    <thead>
                        <tr>
                            <th>Technician</th>
                            <th>Specialization</th>
                            <th>Active jobs</th>
                            <th>Capacity</th>
                            <th>Availability</th>
                            <th class="pm-text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>David Chen</strong><div class="pm-muted" style="font-size:.8rem">Senior HVAC</div></td>
                            <td>HVAC</td>
                            <td>2</td>
                            <td style="min-width:140px"><div class="pm-progress"><div class="pm-progress__bar pm-progress__bar--ok" style="width:40%"></div></div><span class="pm-muted" style="font-size:.75rem">40%</span></td>
                            <td><span class="pm-badge pm-badge--avail">Available</span></td>
                            <td class="pm-text-end"><a class="pm-btn pm-btn--link" asp-controller="Manager" asp-action="AssignTechnician">Assign</a></td>
                        </tr>
                        <tr>
                            <td><strong>Sarah Jenkins</strong><div class="pm-muted" style="font-size:.8rem">Plumbing</div></td>
                            <td>Plumbing</td>
                            <td>5</td>
                            <td><div class="pm-progress"><div class="pm-progress__bar pm-progress__bar--warn" style="width:85%"></div></div><span class="pm-muted" style="font-size:.75rem">85%</span></td>
                            <td><span class="pm-badge pm-badge--busy">Busy</span></td>
                            <td class="pm-text-end"><button type="button" class="pm-btn pm-btn--link" disabled>Busy</button></td>
                        </tr>
                        <tr>
                            <td><strong>Marcus Johnson</strong><div class="pm-muted" style="font-size:.8rem">General</div></td>
                            <td>General</td>
                            <td>6</td>
                            <td><div class="pm-progress"><div class="pm-progress__bar pm-progress__bar--danger" style="width:98%"></div></div><span class="pm-muted" style="font-size:.75rem">98%</span></td>
                            <td><span class="pm-badge pm-badge--busy">Busy</span></td>
                            <td class="pm-text-end"><a class="pm-btn pm-btn--link" asp-controller="Manager" asp-action="AssignTechnician">Reassign</a></td>
                        </tr>
                        <tr>
                            <td><strong>Alex Rivera</strong><div class="pm-muted" style="font-size:.8rem">Electrical</div></td>
                            <td>Electrical</td>
                            <td>1</td>
                            <td><div class="pm-progress"><div class="pm-progress__bar pm-progress__bar--ok" style="width:20%"></div></div><span class="pm-muted" style="font-size:.75rem">20%</span></td>
                            <td><span class="pm-badge pm-badge--avail">Available</span></td>
                            <td class="pm-text-end"><a class="pm-btn pm-btn--link" asp-controller="Manager" asp-action="AssignTechnician">Assign</a></td>
                        </tr>
                        <tr>
                            <td><strong>Priya Nair</strong><div class="pm-muted" style="font-size:.8rem">HVAC</div></td>
                            <td>HVAC</td>
                            <td>0</td>
                            <td><div class="pm-progress"><div class="pm-progress__bar" style="width:5%"></div></div><span class="pm-muted" style="font-size:.75rem">5%</span></td>
                            <td><span class="pm-badge pm-badge--leave">On Leave</span></td>
                            <td class="pm-text-end"><button type="button" class="pm-btn pm-btn--link" disabled>On leave</button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4 d-flex flex-column gap-3">
        <div class="pm-suggestion">
            <h3 class="h6 text-white mb-2">Recommended assignment</h3>
            <p class="mb-3">Urgent HVAC at Building A. David Chen is nearest with healthy capacity.</p>
            <div class="rounded p-3 mb-3" style="background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.25)">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-semibold">REQ-8092</div>
                        <div style="font-size:.85rem;color:var(--pm-secondary)">AC unit failure</div>
                    </div>
                    <span class="pm-badge pm-badge--urgent">Urgent</span>
                </div>
            </div>
            <a class="pm-btn pm-btn--secondary pm-w-100" asp-controller="Manager" asp-action="AssignTechnician">Open assign flow</a>
        </div>
        <div class="pm-card">
            <div class="pm-card__header"><h2 class="pm-card__title">Skill distribution</h2></div>
            <div class="pm-card__body">
                <div class="pm-bar-row">
                    <span class="pm-bar-row__label">Plumbing</span>
                    <div class="pm-bar-row__track"><div class="pm-bar-row__fill" style="width:42%"></div></div>
                    <span class="pm-muted" style="font-size:.8rem;width:3rem;text-align:right">42%</span>
                </div>
                <div class="pm-bar-row">
                    <span class="pm-bar-row__label">HVAC</span>
                    <div class="pm-bar-row__track"><div class="pm-bar-row__fill" style="width:28%"></div></div>
                    <span class="pm-muted" style="font-size:.8rem;width:3rem;text-align:right">28%</span>
                </div>
                <div class="pm-bar-row">
                    <span class="pm-bar-row__label">Electrical</span>
                    <div class="pm-bar-row__track"><div class="pm-bar-row__fill" style="width:18%"></div></div>
                    <span class="pm-muted" style="font-size:.8rem;width:3rem;text-align:right">18%</span>
                </div>
                <div class="pm-bar-row mb-0">
                    <span class="pm-bar-row__label">General</span>
                    <div class="pm-bar-row__track"><div class="pm-bar-row__fill" style="width:12%"></div></div>
                    <span class="pm-muted" style="font-size:.8rem;width:3rem;text-align:right">12%</span>
                </div>
            </div>
        </div>
    </div>
</div>
